# --- web auth (HTTP Basic — gates the whole site) ---
# Single shared username/password for all users. The app refuses to start if
# these are unset. 'admin/admin' is a placeholder: it boots but logs a warning,
# so change it to real credentials before exposing the tunnel publicly.
APP_USER=admin
APP_PASSWORD=admin

# --- server-side sound (off by default) ---
# The container has no audio device, so leave this false and let the launcher play
# sound (it polls /sound). On a Pi with a speaker: set true and map the audio
# device into the container.
ENABLE_SERVER_SOUND=false

# --- Telegram (leave ENABLE_TELEGRAM=false to skip) ---
ENABLE_TELEGRAM=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=


# --- video ---
# Laptop webcam: 0  |  RTSP: rtsp://user:pass@ip:554/stream  |  file: /data/test.mp4
# Multiple cameras: create data/cameras.json (see data/cameras.json.example);
# it replaces VIDEO_SOURCE/ZONE_POINTS and can override the tunables per camera.
VIDEO_SOURCE=0
# RTSP only: force TCP to avoid UDP frame corruption (top cause of garbled frames).
# OPENCV_FFMPEG_CAPTURE_OPTIONS=rtsp_transport;tcp

# How often to run YOLO inference. 3 fps is plenty — persistence is time-based.
# Above ~5 is wasted on a Pi (inference latency dominates).
DETECT_FPS=3.0
# How often to push a frame to the web UI. 10 is indistinguishable from 15 with less CPU.
STREAM_FPS=10.0

# 320 is ~2x faster than 480 with minimal accuracy loss for a dog-sized target.
IMGSZ=320

# --- model ---
# yolo11n = fastest/smallest  |  yolo11s = better accuracy  |  yolo11m = even better
# .pt is auto-exported: NCNN on Pi (ARM), ONNX on laptop (x86).
MODEL=/models/yolo11n.pt
CONF_THRESHOLD=0.35

# --- detection zone (normalized 0..1, flat x,y pairs) ---
# Any polygon: "x1,y1, x2,y2, x3,y3, ..."  Edit it live in the web view; edits
# persist to /data/zone.json and override this on restart (delete that file to revert).
ZONE_POINTS=0.25,0.35, 0.85,0.35, 0.85,0.95, 0.25,0.95
# Fraction of a detection box that must sit inside the zone to count (0 < x <= 1).
# Lower catches dogs on the zone edge; higher rejects dogs merely near it.
ZONE_MIN_OVERLAP=0.6

# --- false-positive suppression ---
# How long the detection persist until trigger
PERSIST_SECONDS=3.0
# Cooldown between triggers
COOLDOWN_SECONDS=30.0

# --- motion gate ---
# YOLO is skipped when fewer than N pixels changed in a 64x64 zone crop.
#   0  = disable (always run YOLO)
#  ~30 = very sensitive (may trigger on camera noise)
#  100 = default — ignores noise, catches any animal-sized movement
#  500 = coarse — only large/fast movements trigger inference
MOTION_THRESHOLD=100
# Run inference at least this often regardless of the gate, so a slow or
# stationary dog is still re-detected.
MOTION_HEARTBEAT_SECONDS=10.0
